<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Message</title>
    <link rel="stylesheet" href="/styles/message.css">
</head>
<body>
    <div class="container">
    <div class="message-card">
        <h2 class="message-heading"><%= message.title %></h2>
        <p class="message-user"><strong>By:</strong> <%= message.username %></p>
        <p class="message-date"><strong>Added:</strong> <%= message.created_at %></p>
        <div class="message-details">
            <p><%= message.message %></p>
        </div>

        <a href="/" class="back-link">← Back to Messages</a>

        <!-- Delete form/button -->
        <form action="/delete/<%= message.id %>" method="post" style="display:inline;">
            <button type="submit" class="delete-button">Delete Message</button>
        </form>
    </div>
</div>
</body>
</html>